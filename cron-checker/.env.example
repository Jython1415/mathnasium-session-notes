# Session Notes Daily Check — Environment Configuration
# Copy this to .env and fill in values
# chmod 600 .env

# ── Radius CRM credentials ────────────────────────────────────────────────────
RADIUS_USERNAME=Joshua.Shew2
RADIUS_PASSWORD=your_radius_password_here
RADIUS_CENTER_ID=2460

# ── OpenRouter AI ─────────────────────────────────────────────────────────────
# Sign up at https://openrouter.ai — get API key from Settings > Keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use for review. Options (cost per 1M input tokens):
#   openai/gpt-4o-mini         $0.15   ← recommended default
#   google/gemini-flash-1.5    $0.075  ← cheaper, good quality
#   anthropic/claude-haiku-4-5-20251001  $0.80  ← same model as web tool
#   google/gemini-2.0-flash    $0.10   ← fast and capable
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Email ─────────────────────────────────────────────────────────────────────
TO_EMAIL=joshua.shew.mathnasium@gmail.com
FROM_EMAIL=noreply@mathsense.com
FROM_NAME=Mathnasium Fresh Pond

# SMTP (optional — leave blank to use PHP mail(), configure for reliable delivery)
# To use Gmail SMTP:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=joshua.shew.mathnasium@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   ← Gmail App Password (not account password)
#     → myaccount.google.com > Security > 2-Step Verification > App passwords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Behavior ─────────────────────────────────────────────────────────────────
# Confidence threshold for flagging (0.0–1.0). Default 0.4 matches web tool.
MIN_CONFIDENCE=0.4

# Records per AI batch. 50 handles a typical day (~40-60 sessions) in one call.
BATCH_SIZE=50

# Send an email even when there are no sessions that day (true/false)
SEND_EMPTY_REPORT=false
